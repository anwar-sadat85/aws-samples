{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "paths": {
      "../../amplify/data/resource": ["./dist-types/amplify/data/resource.d.ts"]
    }
  },
  "include": ["playwright.config.ts", "global-setup.ts", "e2e/**/*.ts"]
}
